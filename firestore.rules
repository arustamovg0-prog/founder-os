rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Вспомогательные функции
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isInvestor() {
      return isAuthenticated() && getUserData().role == 'investor';
    }

    function isFounder() {
      return isAuthenticated() && getUserData().role == 'founder';
    }

    // Правила для коллекции users
    match /users/{userId} {
      allow read: if isAuthenticated(); 
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Правила для коллекции startups
    match /startups/{startupId} {
      allow read: if isAuthenticated();
      // Разрешить создавать стартап любому авторизованному пользователю
      allow create: if isAuthenticated();
      // Обновлять может только если uid есть в founderIds
      allow update: if isAuthenticated() && 
                    (isAdmin() || (request.auth.uid in resource.data.founderIds));
      allow delete: if isAdmin();
    }
    
    // Правила для питчей
    match /pitches/{pitchId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
                   (isAdmin() || 
                   (request.auth.uid == get(/databases/$(database)/documents/startups/$(request.resource.data.startupId)).data.founderIds[0])); // Simple check for now, ideally check if they own the startup
    }
  }
}
