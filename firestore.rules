rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Вспомогательные функции
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isInvestor() {
      return isAuthenticated() && getUserData().role == 'investor';
    }

    function isFounder() {
      return isAuthenticated() && getUserData().role == 'founder';
    }

    // Правила для коллекции users
    match /users/{userId} {
      // Читать может сам пользователь, админ, или инвесторы (для просмотра фаундеров)
      allow read: if isAuthenticated(); 
      // Создавать может только сам пользователь при регистрации
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Обновлять может сам пользователь или админ
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Правила для коллекции startups
    match /startups/{startupId} {
      // Читать могут все авторизованные (инвесторам нужен доступ к Deal Flow)
      allow read: if isAuthenticated();
      
      // Создавать стартап может фаундер (в процессе онбординга)
      allow create: if isFounder() 
        && request.auth.uid in request.resource.data.founderIds;
        
      // Обновлять стартап может фаундер этого стартапа или админ
      allow update: if isAdmin() || (isFounder() && request.auth.uid in resource.data.founderIds);
      
      allow delete: if isAdmin();
    }
    
    // Правила для питчей
    match /pitches/{pitchId} {
      // Фаундеры видят питчи своего стартапа, инвесторы видят питчи, адресованные им, админы видят все
      allow read: if isAdmin() 
        || (isFounder() && request.auth.uid in resource.data.founderIds)
        || (isInvestor() && resource.data.investorId == request.auth.uid);
        
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

  }
}
