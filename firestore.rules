rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Вспомогательные функции ───────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isAuth() && role() == 'admin';
    }

    function isFounder() {
      return isAuth() && role() == 'founder';
    }

    function isInvestor() {
      return isAuth() && role() == 'investor';
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isStartupFounder(startupData) {
      return isAuth() && request.auth.uid in startupData.founderIds;
    }

    // ── users/{userId} ────────────────────────────────────────────────────────
    match /users/{userId} {
      // Пользователь читает/пишет только свой профиль
      allow read, write: if isOwner(userId);
      // Admins читают всех
      allow read: if isAdmin();
      // Публичное создание при регистрации
      allow create: if isAuth() && request.auth.uid == userId;
    }

    // ── startups/{startupId} ─────────────────────────────────────────────────
    match /startups/{startupId} {
      // Founder читает и редактирует только свои стартапы
      allow read, write: if isAuth() &&
        request.auth.uid in resource.data.founderIds;

      // Инвесторы видят только investment_ready стартапы
      allow read: if isInvestor() &&
        resource.data.status == 'investment_ready';

      // Admin — полный доступ
      allow read, write: if isAdmin();

      // Создание стартапа (только founder)
      allow create: if isFounder() &&
        request.auth.uid in request.resource.data.founderIds;
    }

    // ── roadmap_stages/{stageId} (системные шаблоны, read-only) ─────────────
    match /roadmap_stages/{stageId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── startup_roadmap_progress/{startupId}/stages/{stageId} ────────────────
    match /startup_roadmap_progress/{startupId}/stages/{stageId} {
      allow read: if isAuth() && (
        isAdmin() ||
        request.auth.uid in get(/databases/$(database)/documents/startups/$(startupId)).data.founderIds
      );
      // Founder обновляет прогресс
      allow write: if isAuth() &&
        request.auth.uid in get(/databases/$(database)/documents/startups/$(startupId)).data.founderIds;
      // Admin верифицирует стадии
      allow write: if isAdmin();
    }

    // ── digital_footprint/{startupId}/logs/{logId} ───────────────────────────
    match /digital_footprint/{startupId}/logs/{logId} {
      // Читают: founder своего стартапа, investor (investment_ready), admin
      allow read: if isAdmin() ||
        (isAuth() && request.auth.uid in get(/databases/$(database)/documents/startups/$(startupId)).data.founderIds) ||
        (isInvestor() && get(/databases/$(database)/documents/startups/$(startupId)).data.status == 'investment_ready');

      // Запись — только Cloud Functions (service account)
      allow write: if false;
    }

    // ── pitch_events/{pitchId} ────────────────────────────────────────────────
    match /pitch_events/{pitchId} {
      // Читают: участники питча + admin
      allow read: if isAdmin() ||
        (isAuth() && (
          request.auth.uid == resource.data.investorId ||
          request.auth.uid in resource.data.founderIds
        ));

      // Founder создаёт питч-запрос
      allow create: if isFounder() &&
        request.auth.uid in request.resource.data.founderIds;

      // Обновление — только через API (Cloud Functions), либо investor отвечает
      allow update: if isInvestor() &&
        request.auth.uid == resource.data.investorId;

      // Admin — полный доступ
      allow read, write: if isAdmin();
    }

    // ── onboarding/{userId} ───────────────────────────────────────────────────
    match /onboarding/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

  }
}
