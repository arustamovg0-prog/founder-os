rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Вспомогательные функции ─────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuth() && request.auth.token.role == 'admin';
    }
    function maxSize(mb) {
      return request.resource.size < mb * 1024 * 1024;
    }
    function isPDF() {
      return request.resource.contentType.matches('application/pdf');
    }
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    // ── startup_documents/{startupId}/{fileName} ─────────────────────────────
    // Pitch deck, финансовые модели, executive summary
    match /startup_documents/{startupId}/{fileName} {
      allow read: if isAuth();
      // Require user to be founder or admin to write, basic check for now
      allow write: if isAuth(); 
    }

    // ── avatars/{userId}/{fileName} ──────────────────────────────────────────
    match /avatars/{userId}/{fileName} {
      allow read: if isAuth();
      allow write: if isAuth() &&
        request.auth.uid == userId &&
        isImage() &&
        maxSize(5);
    }

  }
}
