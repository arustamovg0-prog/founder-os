[debug] [2026-07-15T18:37:45.819Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/founder-os-78cfc/rulesets {"name":"projects/founder-os-78cfc/rulesets/3d14db3e-3ce9-4cce-b107-7f8ccfc9dab6","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Вспомогательные функции\n    function isAuthenticated() {\n      return request.auth != null;\n    }\n    \n    function getUserData() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;\n    }\n    \n    function isAdmin() {\n      return isAuthenticated() && getUserData().role == 'admin';\n    }\n\n    function isInvestor() {\n      return isAuthenticated() && getUserData().role == 'investor';\n    }\n\n    function isFounder() {\n      return isAuthenticated() && getUserData().role == 'founder';\n    }\n\n    // Правила для коллекции users\n    match /users/{userId} {\n      allow read: if isAuthenticated(); \n      allow write: if isAuthenticated() && request.auth.uid == userId;\n    }\n\n    // Правила для коллекции startups\n    match /startups/{startupId} {\n      allow read: if isAuthenticated();\n      // Разрешить создавать стартап любому авторизованному пользователю\n      allow create: if isAuthenticated();\n      // Обновлять может только если uid есть в founderIds\n      allow update: if isAuthenticated() && \n                    (isAdmin() || (request.auth.uid in resource.data.founderIds));\n      allow delete: if isAdmin();\n    }\n    \n    // Правила для питчей\n    match /pitches/{pitchId} {\n      allow read: if isAuthenticated();\n      allow write: if isAuthenticated() && \n                   (isAdmin() || \n                   (request.auth.uid == get(/databases/$(database)/documents/startups/$(request.resource.data.startupId)).data.founderIds[0])); // Simple check for now, ideally check if they own the startup\n    }\n\n    // Журнал доказательств (Append-Only Evidence Record)\n    // Доступ с клиента полностью закрыт. Чтение и запись только через Admin SDK (Server Actions).\n    match /audit_evidence/{recordId} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-07-15T18:37:46.657407Z","metadata":{"services":["cloud.firestore"]}}
